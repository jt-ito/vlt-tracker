{
  "name": "vlt-tracker",
  "version": "1.0.2",
  "description": "VLT Tracker — a local manga/doujin library tracker with import, tagging, and API integrations",
  "main": "main.js",
  "author": "jt-ito",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "web": "node server.js",
    "setup-chromium": "node scripts/setup-chromium.js",
    "dist": "npm run setup-chromium && electron-builder --win",
    "dist:all": "npm run setup-chromium && electron-builder --win --linux --mac"
  },
  "puppeteer": {
    "skipChromeHeadlessShellDownload": true
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "express": "^4.19.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "puppeteer": "^22.0.0",
    "rate-limiter-flexible": "^11.1.0"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.jteaito.vlt-tracker",
    "productName": "VLT Tracker",
    "copyright": "Copyright © 2026 jt-ito",
    "directories": {
      "output": "dist"
    },
    "asarUnpack": [
      ".puppeteer-cache/**/*"
    ],
    "files": [
      "index.html",
      "main.js",
      "server.js",
      "package.json",
      "package-lock.json",
      "extensions/**/*",
      ".puppeteer-cache/**/*",
      "node_modules/**/*",
      "!node_modules/electron-builder/**",
      "!node_modules/electron/dist/**",
      "!dist/**",
      "!scripts/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "VLT-Tracker-Setup-${version}.exe"
    },
    "portable": {
      "artifactName": "VLT-Tracker-Portable-${version}.exe"
    }
  }
}
